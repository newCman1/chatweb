CHATWEB_ENV=production
CHATWEB_LOG_LEVEL=INFO
CHATWEB_DEFAULT_STREAM_FORMAT=json
CHATWEB_TOKEN_DELAY_SECONDS=0.03
CHATWEB_REQUEST_TIMEOUT_MS=15000
CHATWEB_AI_API_KEY=
CHATWEB_AI_MODEL=deepseek-chat
CHATWEB_AI_REASONING_MODEL=deepseek-reasoner
CHATWEB_AI_BASE_URL=https://api.deepseek.com/v1
CHATWEB_AI_TIMEOUT_SECONDS=60
CHATWEB_AI_HTTP_TRUST_ENV=false
CHATWEB_AI_REASONING_EFFORT=medium
CHATWEB_AI_SEND_REASONING_EFFORT=false
CHATWEB_THINKING_ENABLED=false
CHATWEB_AI_FALLBACK_ON_ERROR=false
