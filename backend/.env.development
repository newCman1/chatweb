CHATWEB_ENV=development
CHATWEB_LOG_LEVEL=DEBUG
CHATWEB_DEFAULT_STREAM_FORMAT=json
CHATWEB_TOKEN_DELAY_SECONDS=0.05
CHATWEB_REQUEST_TIMEOUT_MS=10000
CHATWEB_AI_API_KEY=
CHATWEB_AI_MODEL=gpt-4.1-mini
CHATWEB_AI_BASE_URL=https://api.openai.com/v1
CHATWEB_AI_TIMEOUT_SECONDS=60
CHATWEB_AI_REASONING_EFFORT=medium
CHATWEB_THINKING_ENABLED=true
CHATWEB_AI_FALLBACK_ON_ERROR=true
